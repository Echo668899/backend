<script>
    layui.use(['index', 'form', 'laydate', 'upload'], function () {
        var $ = layui.$
            , element = layui.element
            , laydate = layui.laydate
            , upload = layui.upload
            , form = layui.form
            , row = <?php echo json_encode($row);?>;

        form.val('info-form', row);
        form.render(null, 'info-form');

        element.render('breadcrumb', 'breadcrumb');

        //回显部分数据
        if(row){
            if (row.img_x) {
                $("#imgX").html("<img width='102' height='102' src='<?php echo $mediaUrl;?>" + row.img_x + "'>");
            }
            if (row.tpl_config && row.tpl_config.max_times_per_day !== undefined) {
                $("[name='tpl_config[max_times_per_day]']").val(row.tpl_config.max_times_per_day);
            }
            if (row.tpl_config && row.tpl_config.prizes) {
                row.tpl_config.prizes.forEach(function (item) {
                    addPrize(item);
                });
            }
            if (row.tpl_config && row.tpl_config.mode) {
                $("#mode-select").val(row.tpl_config.mode);
            }
            if (row.tpl_config && row.tpl_config.mode_value) {
                $("[name='tpl_config[mode_value]']").val(row.tpl_config.mode_value);
            }
        }

        form.render('select');

        //时间
        laydate.render({
            elem: '#end_time',
            type: 'datetime'
        });
        laydate.render({
            elem: '#start_time',
            type: 'datetime'
        });

        //上传图片
        upload.render({
            elem: '#imgX' //绑定元素
            , url: '<?php echo $uploadUrl; ?>' //上传接口
            , before: function (obj) {
                layer.load(0, {time: 30 * 1000});
            }
            , done: function (res) {
                layer.closeAll('loading');
                if (res.status == 'y') {
                    $("#imgX").html("<img width='102' height='102' src='<?php echo $mediaUrl;?>" + res.data + "'>");
                    $("#imgXInput").val(res.data);
                } else {
                    showErrorMsg(res.error)
                }
            }
            , error: function () {
                //请求异常回调
                showErrorMsg('上传异常')
            }
        });

        form.on('submit(info-form)', function (obj) {
            var loadIndex = layer.load(0, {time: 30 * 1000});
            doAjax("<?php echo url()->get('/activity/save')?>", obj.field, function (res) {
                layer.close(loadIndex);
                if (res.status === 'y') {
                    showSuccessMsg("保存成功!");
                    parent.layer.close(parent.layerIndex);
                    parent.table.reload('table');
                    return;
                }
                showErrorMsg(res.error);
            });
            return false;
        });

    });
    function addPrize(data = {}) {
        let index = $("#prize-table tr").length;

        let rowHtml = `
<tr id="prize-${index}">
    <td>
        <input name="tpl_config[prizes][${index}][name]" value="${data.name ?? ''}" class="layui-input">
    </td>

    <td>
        <input type="number" name="tpl_config[prizes][${index}][num]" value="${data.num ?? ''}" class="layui-input">
    </td>
    <td>
        <input type="number" name="tpl_config[prizes][${index}][rate]" value="${data.rate ?? ''}" class="layui-input">
    </td>

    <td>
        <div id="imgX_${index}" class="upload-select-picture-card">
            ${
            data.image
                ? `<img width="102" height="102" src="<?php echo $mediaUrl;?>${data.image}">`
                : '<span class="layui-icon layui-icon-addition"></span>'
        }
        </div>
        <input name="tpl_config[prizes][${index}][image]" id="imgXInput_${index}" value="${data.image ?? ''}" type="hidden" class="layui-input"/>
    </td>

    <td>
        <select name="tpl_config[prizes][${index}][type]">
            <option value="vip"    ${data.type === 'vip' ? 'selected' : ''}>vip | 会员</option>
            <option value="point"  ${data.type === 'point' ? 'selected' : ''}>point | 金币</option>
            <option value="credit" ${data.type === 'credit' ? 'selected' : ''}>credit | 积分</option>
            <option value="entity" ${data.type === 'entity' ? 'selected' : ''}>entity | 实物</option>
            <option value="none"   ${data.type === 'none' ? 'selected' : ''}>none | 无奖品</option>
        </select>
    </td>

    <td>
        <button type="button" class="layui-btn layui-btn-danger layui-btn-xs" onclick="removePrize(${index})">删除</button>
    </td>
</tr>
`;

        $("#prize-table").append(rowHtml);

        layui.form.render(); // 渲染 select

        // ⭐ 初始化这一行的上传
        initPrizeUpload(index);
    }

    function removePrize(index) {
        $("#prize-" + index).remove();
    }


    function initPrizeUpload(index) {
        layui.upload.render({
            elem: '#imgX_' + index  // 每行自己的 div
            , url: '<?php echo $uploadUrl; ?>'
            , before: function (obj) {
                layer.load(0, {time: 30 * 1000});
            }
            , done: function (res) {
                layer.closeAll('loading');
                if (res.status == 'y') {
                    // 更新当前这一行的预览图
                    $("#imgX_" + index).html(
                        "<img width='102' height='102' src='<?php echo $mediaUrl;?>" + res.data + "'>"
                    );
                    // 把地址写入这一行的隐藏 input
                    $("#imgXInput_" + index).val(res.data);
                } else {
                    showErrorMsg(res.error)
                }
            }
            , error: function () {
                showErrorMsg('上传异常')
            }
        });
    }


</script>
