<script>
    layui.use(['index', 'form', 'laydate', 'upload'], function () {
        var $ = layui.$
            , element = layui.element
            , laydate = layui.laydate
            , upload = layui.upload
            , form = layui.form
            , row = <?php echo json_encode($row);?>;

        form.val('info-form', row);
        form.render(null, 'info-form');

        element.render('breadcrumb', 'breadcrumb');

        //回显部分数据
        if (row) {
            if (row.img_x) {
                $("#imgX").html("<img width='102' height='102' src='<?php echo $mediaUrl;?>" + row.img_x + "'>");
            }
            if (row.right) {
                selectRight(row.tpl_config.right);
            }
            if (row.tpl_config && row.tpl_config.show_time) {
                $("[name='tpl_config[show_time]']").val(row.tpl_config.show_time);
            }
            if (row.tpl_config && row.tpl_config.wait_time) {
                $("[name='tpl_config[wait_time]']").val(row.tpl_config.wait_time);
            }
            if (row.tpl_config && row.tpl_config.end_type) {
                $("[name='tpl_config[end_type]'][value='" + row.tpl_config.end_type + "']").prop("checked", true);
            }
            if (row.tpl_config && row.tpl_config.time) {
                $("[name='tpl_config[time]']").val(row.tpl_config.time);
            }
            if (row.tpl_config && row.tpl_config.link) {
                $("[name='tpl_config[link]']").val(row.tpl_config.link);
            }
            if (row.tpl_config && row.tpl_config.is_show_time) {
                $("[name='tpl_config[is_show_time]'][value='" + row.tpl_config.is_show_time + "']").prop("checked", true);
            }
            if (row.right) {
                selectRight(row.right)
            }
            if (row.tpl_config && row.tpl_config.end_type) {
                selectEndType(row.tpl_config.end_type)
            }
        }
        form.render('radio');
        form.render('select');

        //时间
        laydate.render({
            elem: '#end_time',
            type: 'datetime'
        });
        laydate.render({
            elem: '#start_time',
            type: 'datetime'
        });
        //选择类型
        form.on('radio(radio-right)', function (data) {
            selectRight(data.value);
        });
        //选择
        form.on('radio(radio-end_type)', function (data) {
            selectEndType(data.value);
        });

        function selectRight(value){
            if (value === 'all') {
                $(".select-right-normal").hide();
                $(".select-right-vip").hide();
            } else if (value === 'normal') {
                $(".select-right-normal").show();
                $(".select-right-vip").hide();
            } else if (value === 'vip') {
                $(".select-right-normal").hide();
                $(".select-right-vip").show();
            }
        }
        function selectEndType(value){
            if (value === 'gt') {
                $('.vip_remaining_time_type_gt').show();
                $('.vip_remaining_time_type_lt').hide();
            } else if (value === 'lt') {
                $('.vip_remaining_time_type_gt').hide();
                $('.vip_remaining_time_type_lt').show();
            }
        }

        //上传图片
        upload.render({
            elem: '#imgX' //绑定元素
            , url: '<?php echo $uploadUrl; ?>' //上传接口
            , before: function (obj) {
                layer.load(0, {time: 30 * 1000});
            }
            , done: function (res) {
                layer.closeAll('loading');
                if (res.status == 'y') {
                    $("#imgX").html("<img width='102' height='102' src='<?php echo $mediaUrl;?>" + res.data + "'>");
                    $("#imgXInput").val(res.data);
                } else {
                    showErrorMsg(res.error)
                }
            }
            , error: function () {
                //请求异常回调
                showErrorMsg('上传异常')
            }
        });

        form.on('submit(info-form)', function (obj) {
            var loadIndex = layer.load(0, {time: 30 * 1000});
            doAjax("<?php echo url()->get('/activity/save')?>", obj.field, function (res) {
                layer.close(loadIndex);
                if (res.status === 'y') {
                    showSuccessMsg("保存成功!");
                    parent.layer.close(parent.layerIndex);
                    parent.table.reload('table');
                    return;
                }
                showErrorMsg(res.error);
            });
            return false;
        });

    });


</script>
